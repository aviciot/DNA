"""
Catalog Templates Management API

Endpoints for managing built templates (parsed from reference documents)
"""

import json
import logging
from typing import List, Optional
from uuid import UUID
from datetime import datetime
from fastapi import APIRouter, HTTPException, Depends
from pydantic import BaseModel, Field

from ..database import get_db_pool
from ..auth import get_current_user, require_admin
from ..config import settings

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/catalog-templates", tags=["Catalog Templates"])


# =============================================================================
# Pydantic Models
# =============================================================================

class CatalogTemplateBase(BaseModel):
    """Base model for catalog template"""
    name: str
    description: Optional[str] = None
    version: Optional[str] = None
    notes: Optional[str] = None


class CatalogTemplateUpdate(BaseModel):
    """Model for updating catalog template"""
    name: Optional[str] = None
    description: Optional[str] = None
    version: Optional[str] = None
    notes: Optional[str] = None
    status: Optional[str] = None  # draft, approved, archived


class CatalogTemplateResponse(BaseModel):
    """Response model for catalog template"""
    id: UUID
    name: str
    description: Optional[str]
    template_file_id: Optional[UUID]
    source_filename: Optional[str]
    status: str
    version: Optional[str]
    section_count: int
    field_count: int
    required_field_count: int
    estimated_completion_minutes: Optional[int]
    iso_codes: List[str] = Field(default_factory=list)
    created_at: datetime
    updated_at: datetime
    approved_at: Optional[datetime]
    customer_document_count: int = 0

    class Config:
        from_attributes = True


class CatalogTemplateDetailResponse(CatalogTemplateResponse):
    """Detailed response with template structure"""
    template_structure: dict
    ai_task_id: Optional[UUID]
    created_by_email: Optional[str]
    approved_by_email: Optional[str]


class ISOAssignmentRequest(BaseModel):
    """Request model for assigning ISOs to template"""
    iso_standard_ids: List[UUID]


# =============================================================================
# API Endpoints
# =============================================================================

@router.get("", response_model=List[CatalogTemplateResponse])
async def list_catalog_templates(
    status: Optional[str] = None,
    iso_standard_id: Optional[UUID] = None,
    current_user: dict = Depends(get_current_user)
):
    """
    List all catalog templates.

    Query Parameters:
        - status: Filter by status (draft, approved, archived)
        - iso_standard_id: Filter by ISO standard

    Returns:
        List of catalog templates with metadata
    """
    try:
        pool = await get_db_pool()
        async with pool.acquire() as conn:
            query = f"""
                SELECT
                    id, name, description, template_file_id, source_filename,
                    status, version, section_count, field_count, required_field_count,
                    estimated_completion_minutes, iso_codes,
                    created_at, updated_at, approved_at, customer_document_count
                FROM {settings.DATABASE_APP_SCHEMA}.v_catalog_templates_with_details
                WHERE 1=1
            """

            params = []
            param_count = 1

            if status:
                query += f" AND status = ${param_count}"
                params.append(status)
                param_count += 1

            if iso_standard_id:
                # Filter by ISO standard
                iso_code = await conn.fetchval(
                    f"SELECT code FROM {settings.DATABASE_APP_SCHEMA}.iso_standards WHERE id = $1",
                    iso_standard_id
                )
                if iso_code:
                    query += f" AND ${param_count} = ANY(iso_codes)"
                    params.append(iso_code)
                    param_count += 1

            query += " ORDER BY created_at DESC"

            rows = await conn.fetch(query, *params)

            return [dict(row) for row in rows]

    except Exception as e:
        logger.error(f"Error listing catalog templates: {e}")
        raise HTTPException(500, f"Failed to list catalog templates: {str(e)}")


@router.get("/{template_id}", response_model=CatalogTemplateDetailResponse)
async def get_catalog_template(
    template_id: UUID,
    current_user: dict = Depends(get_current_user)
):
    """
    Get detailed information about a catalog template.

    Returns:
        Template details including full structure
    """
    try:
        pool = await get_db_pool()
        async with pool.acquire() as conn:
            row = await conn.fetchrow(f"""
                SELECT *
                FROM {settings.DATABASE_APP_SCHEMA}.v_catalog_templates_with_details
                WHERE id = $1
            """, template_id)

            if not row:
                raise HTTPException(404, f"Catalog template {template_id} not found")

            # Convert row to dict and parse template_structure from JSON string to dict
            result = dict(row)

            # Parse template_structure if it's a string
            if isinstance(result.get('template_structure'), str):
                result['template_structure'] = json.loads(result['template_structure'])

            return result

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error getting catalog template {template_id}: {e}")
        raise HTTPException(500, f"Failed to get catalog template: {str(e)}")


@router.put("/{template_id}", response_model=CatalogTemplateResponse)
async def update_catalog_template(
    template_id: UUID,
    template_data: CatalogTemplateUpdate,
    current_user: dict = Depends(require_admin)
):
    """
    Update catalog template metadata.

    Requires: Admin role

    Returns:
        Updated template
    """
    try:
        pool = await get_db_pool()
        async with pool.acquire() as conn:
            # Check if exists
            existing = await conn.fetchrow(
                f"SELECT id, status FROM {settings.DATABASE_APP_SCHEMA}.catalog_templates WHERE id = $1",
                template_id
            )

            if not existing:
                raise HTTPException(404, f"Catalog template {template_id} not found")

            # Build dynamic update query
            updates = []
            values = []
            param_count = 1

            if template_data.name is not None:
                updates.append(f"name = ${param_count}")
                values.append(template_data.name)
                param_count += 1

            if template_data.description is not None:
                updates.append(f"description = ${param_count}")
                values.append(template_data.description)
                param_count += 1

            if template_data.version is not None:
                updates.append(f"version = ${param_count}")
                values.append(template_data.version)
                param_count += 1

            if template_data.notes is not None:
                updates.append(f"notes = ${param_count}")
                values.append(template_data.notes)
                param_count += 1

            if template_data.status is not None:
                if template_data.status not in ['draft', 'approved', 'archived']:
                    raise HTTPException(400, "Status must be: draft, approved, or archived")

                updates.append(f"status = ${param_count}")
                values.append(template_data.status)
                param_count += 1

                # If approving, set approved_at and approved_by
                if template_data.status == 'approved' and existing['status'] != 'approved':
                    updates.append(f"approved_at = NOW()")
                    updates.append(f"approved_by = ${param_count}")
                    values.append(current_user.get('user_id'))
                    param_count += 1

            if not updates:
                raise HTTPException(400, "No fields to update")

            # Add updated_at
            updates.append(f"updated_at = NOW()")

            # Add template_id as last parameter
            values.append(template_id)

            query = f"""
                UPDATE {settings.DATABASE_APP_SCHEMA}.catalog_templates
                SET {', '.join(updates)}
                WHERE id = ${param_count}
            """

            await conn.execute(query, *values)

            logger.info(f"Updated catalog template {template_id} by user {current_user.get('user_id')}")

            # Return updated template
            return await get_catalog_template(template_id, current_user)

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error updating catalog template {template_id}: {e}")
        raise HTTPException(500, f"Failed to update catalog template: {str(e)}")


@router.delete("/{template_id}", status_code=204)
async def delete_catalog_template(
    template_id: UUID,
    current_user: dict = Depends(require_admin)
):
    """
    Delete a catalog template.

    Requires: Admin role

    Note: This will fail if customers are using this template.
    """
    try:
        pool = await get_db_pool()
        async with pool.acquire() as conn:
            # Check if exists
            existing = await conn.fetchrow(
                f"SELECT id FROM {settings.DATABASE_APP_SCHEMA}.catalog_templates WHERE id = $1",
                template_id
            )

            if not existing:
                raise HTTPException(404, f"Catalog template {template_id} not found")

            # TODO: Check if in use by customers
            # customer_count = await conn.fetchval(...)
            # if customer_count > 0:
            #     raise HTTPException(400, "Cannot delete: template is in use by customers")

            # Delete (CASCADE will delete ISO mappings)
            await conn.execute(
                f"DELETE FROM {settings.DATABASE_APP_SCHEMA}.catalog_templates WHERE id = $1",
                template_id
            )

            logger.info(f"Deleted catalog template {template_id} by user {current_user.get('user_id')}")

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error deleting catalog template {template_id}: {e}")
        raise HTTPException(500, f"Failed to delete catalog template: {str(e)}")


@router.patch("/{template_id}/iso-standards", response_model=CatalogTemplateResponse)
async def update_template_iso_assignments(
    template_id: UUID,
    assignment: ISOAssignmentRequest,
    current_user: dict = Depends(require_admin)
):
    """
    Update ISO standard assignments for a catalog template.

    Requires: Admin role

    This replaces all existing ISO assignments with the new list.

    Body:
        iso_standard_ids: List of ISO standard UUIDs

    Returns:
        Updated template
    """
    try:
        pool = await get_db_pool()
        async with pool.acquire() as conn:
            # Check template exists
            exists = await conn.fetchval(
                f"SELECT EXISTS(SELECT 1 FROM {settings.DATABASE_APP_SCHEMA}.catalog_templates WHERE id = $1)",
                template_id
            )

            if not exists:
                raise HTTPException(404, f"Catalog template {template_id} not found")

            # Validate ISO standard IDs
            if assignment.iso_standard_ids:
                valid_ids = await conn.fetch(
                    f"SELECT id FROM {settings.DATABASE_APP_SCHEMA}.iso_standards WHERE id = ANY($1)",
                    assignment.iso_standard_ids
                )

                found_ids = [row['id'] for row in valid_ids]
                missing_ids = set(assignment.iso_standard_ids) - set(found_ids)

                if missing_ids:
                    raise HTTPException(404, f"ISO standards not found: {missing_ids}")

            # Delete existing mappings
            await conn.execute(
                f"DELETE FROM {settings.DATABASE_APP_SCHEMA}.catalog_template_iso_mapping WHERE catalog_template_id = $1",
                template_id
            )

            # Insert new mappings
            for iso_id in assignment.iso_standard_ids:
                await conn.execute(f"""
                    INSERT INTO {settings.DATABASE_APP_SCHEMA}.catalog_template_iso_mapping
                    (catalog_template_id, iso_standard_id, created_by)
                    VALUES ($1, $2, $3)
                """, template_id, iso_id, current_user.get('user_id'))

            # Update template updated_at
            await conn.execute(
                f"UPDATE {settings.DATABASE_APP_SCHEMA}.catalog_templates SET updated_at = NOW() WHERE id = $1",
                template_id
            )

            logger.info(f"Updated ISO assignments for catalog template {template_id} by user {current_user.get('user_id')}")

            # Return updated template
            return await get_catalog_template(template_id, current_user)

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error updating ISO assignments for {template_id}: {e}")
        raise HTTPException(500, f"Failed to update ISO assignments: {str(e)}")
