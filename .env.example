# DNA Environment Configuration

# ============================================================
# Security Keys (CHANGE IN PRODUCTION!)
# ============================================================
SECRET_KEY=dna-secret-key-change-in-production-use-random-64-chars
JWT_SECRET_KEY=dna-jwt-secret-key-change-in-production-use-random-64-chars

# ============================================================
# Database Configuration
# ============================================================
DATABASE_HOST=dna-postgres
DATABASE_PORT=5432
DATABASE_NAME=dna
DATABASE_USER=dna_user
DATABASE_PASSWORD=dna_password_dev

# ============================================================
# Claude API Configuration
# ============================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=4096

# ============================================================
# Service URLs (Docker internal)
# ============================================================
AUTH_SERVICE_URL=http://dna-auth:8401
BACKEND_URL=http://dna-backend:8400

# ============================================================
# CORS Origins (comma-separated)
# ============================================================
CORS_ORIGINS=http://localhost:3003,http://localhost:8400

# ============================================================
# JWT Configuration
# ============================================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# Customer Portal
# ============================================================
PORTAL_DB_PASSWORD=portal_pass_change_in_production
PORT_PORTAL_BACKEND=4010
PORT_PORTAL_FRONTEND=4000
REQUIRE_AV_SCAN=true
PORTAL_URL=http://localhost:4000

# ============================================================
# Cloudflare Zero Trust
# ============================================================
# Set CF_BYPASS_LOCAL=false in production
CF_BYPASS_LOCAL=true
CF_TEAM_DOMAIN=yourteam.cloudflareaccess.com
CF_APP_AUD=your-cf-app-audience-tag-here
CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
CF_DNA_HOSTNAME=dna.yourcompany.com
CF_PORTAL_HOSTNAME=portal.yourcompany.com
# Internal service-to-service auth token (generate with: openssl rand -hex 32)
CF_INTERNAL_SERVICE_TOKEN=change-me-in-production

# ============================================================
# Frontend (CF mode)
# ============================================================
# Set NEXT_PUBLIC_CF_BYPASS=false in production
NEXT_PUBLIC_CF_BYPASS=true
NEXT_PUBLIC_DEV_LOGIN_HELPER=true
NEXT_PUBLIC_CF_TEAM_DOMAIN=yourteam.cloudflareaccess.com
